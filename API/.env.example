# ============================================================
# Reactivities – environment variables template
# Copy this file to .env (in the API/ folder) and fill in
# your own values. The .env file is git-ignored.
# ============================================================

# Cloudinary (image uploads)
# Get values from https://cloudinary.com/console
CloudinarySettings__CloudName=your-cloud-name
CloudinarySettings__ApiKey=your-api-key
CloudinarySettings__ApiSecret=your-api-secret

# Gmail SMTP (email confirmations)
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SmtpSettings__UserName=your-email@gmail.com
SmtpSettings__Password=xxxx xxxx xxxx xxxx
SmtpSettings__FromEmail=your-email@gmail.com
